        "severity": "ERROR",
        "tags": ["hesa", "programme"],
        "messageTemplate": "Engagement {{id}} for 2024/25 has no programmeCode",
        "where": {
          "kind": "and",
          "clauses": [
            { "kind": "predicate", "op": "eq", "field": { "kind": "field", "entity": "Engagement", "field": "collectionYear" }, "operands": [{ "kind": "literal", "value": "2024/25" }] },
            { "kind": "predicate", "op": "isNull", "field": { "kind": "field", "entity": "Engagement", "field": "programmeCode" }, "operands": [] }
          ]
        }
      }
    },
