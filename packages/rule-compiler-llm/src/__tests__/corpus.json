        "severity": "ERROR",
        "tags": ["effective-dating"],
        "messageTemplate": "Engagement {{id}} ends ({{endDate}}) before it starts ({{startDate}})",
        "where": {
          "kind": "and",
          "clauses": [
            { "kind": "predicate", "op": "isNotNull", "field": { "kind": "field", "entity": "Engagement", "field": "endDate" }, "operands": [] },
            { "kind": "predicate", "op": "isNotNull", "field": { "kind": "field", "entity": "Engagement", "field": "startDate" }, "operands": [] },
            { "kind": "predicate", "op": "lt", "field": { "kind": "field", "entity": "Engagement", "field": "endDate" }, "operands": [{ "kind": "field", "entity": "Engagement", "field": "startDate" }] }
          ]
        }
      }
