{
  "version": "0.1.0",
  "description": "50 NL → LlmRule pairs covering canonical Student/Engagement/Module entities plus the source-shaped variants (Banner, SITS, Workday, TechOne, Salesforce, Dynamics). Used by the regression suite with DeterministicMockProvider — never sent to a real provider.",
  "entries": [
    {
      "id": "corpus-01",
      "nl": "students with no last name",
      "expected": {
        "id": "students-missing-lastname",
        "entity": "Student",
        "name": "Students missing lastName",
        "description": "Students whose lastName is null or empty.",
        "severity": "ERROR",
        "tags": ["identity"],
        "messageTemplate": "Student {{sourceId}} is missing lastName",
        "where": { "kind": "predicate", "op": "isNull", "field": { "kind": "field", "entity": "Student", "field": "lastName" }, "operands": [] }
      }
    },
    {
      "id": "corpus-02",
      "nl": "students with no husid",
      "expected": {
        "id": "students-missing-husid",
        "entity": "Student",
        "name": "Students missing HUSID",
        "description": "Students whose HESA Unique Student Identifier is null.",
        "severity": "WARN",
        "tags": ["identity", "hesa"],
        "messageTemplate": "Student {{sourceId}} is missing HUSID",
        "where": { "kind": "predicate", "op": "isNull", "field": { "kind": "field", "entity": "Student", "field": "husid" }, "operands": [] }
      }
    },
    {
      "id": "corpus-03",
      "nl": "students with email shared at uni.example",
      "expected": {
        "id": "students-shared-email",
        "entity": "Student",
        "name": "Students with shared placeholder email",
        "description": "Students whose email is the shared placeholder.",
        "severity": "WARN",
        "tags": ["identity"],
        "messageTemplate": "Student {{sourceId}} has placeholder email {{email}}",
        "where": { "kind": "predicate", "op": "eq", "field": { "kind": "field", "entity": "Student", "field": "email" }, "operands": [{ "kind": "literal", "value": "shared@uni.example" }] }
      }
    },
    {
