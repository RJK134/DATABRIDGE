{
  "name": "@databridge/schema-mapper-llm",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "LLM-assisted schema-mapping suggester. Wraps the deterministic SchemaSuggester; when deterministic confidence is below threshold, calls an LLM tie-breaker with an explanation. Deterministic suggester remains the source of truth.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@databridge/schema-mapper": "workspace:*",
    "@databridge/rule-compiler-llm": "workspace:*",
    "@databridge/provenance-core": "workspace:*",
    "zod": "^3.23.0"
  },
  "peerDependencies": {
    "onnxruntime-node": "^1.17.0"
  },
  "peerDependenciesMeta": {
    "onnxruntime-node": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  }
}
