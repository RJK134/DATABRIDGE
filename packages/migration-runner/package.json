{
  "name": "@databridge/migration-runner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Phase J3 — migration runner. Reads a migration-policy bundle, drives source rows through canonical projection and target write via TargetAdapter, emitting per-row provenance, dry-run diff, and a rollback log.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@databridge/adapter-spec": "workspace:*",
    "@databridge/migration-policy": "workspace:*",
    "@databridge/target-adapters": "workspace:*",
    "@databridge/codeset-mapper": "workspace:*",
    "@databridge/platform": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "vitest": "^1.6.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/parser": "^7.8.0",
    "@typescript-eslint/eslint-plugin": "^7.8.0"
  }
}
