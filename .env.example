# ============================================================
# DataBridge Environment Configuration Template
# Copy to .env.local — NEVER commit secrets
# ============================================================

# --- Database (Neon / Postgres) ---
DATABASE_URL="postgresql://user:password@localhost:5432/databridge"
DIRECT_URL="postgresql://user:password@localhost:5432/databridge"

# --- Auth (Keycloak) ---
KEYCLOAK_URL="http://localhost:8080"
KEYCLOAK_REALM="databridge"
KEYCLOAK_CLIENT_ID="databridge-api"
KEYCLOAK_CLIENT_SECRET=""

# --- API ---
API_PORT=3001
API_HOST="0.0.0.0"
NODE_ENV="development"
LOG_LEVEL="info"

# --- Object Store (R2 / S3-compatible) ---
S3_ENDPOINT=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_BUCKET="databridge-objects"
S3_REGION="auto"

# --- AI (dual-vendor) ---
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
LLM_PRIMARY="anthropic"
LLM_FALLBACK="openai"
LLM_EU_ONLY="true"

# --- Secrets Vault ---
SECRETS_PROVIDER="env"
DOPPLER_TOKEN=""

# --- Telemetry ---
OTEL_EXPORTER_OTLP_ENDPOINT=""
OTEL_SERVICE_NAME="databridge-api"

# --- Feature Flags ---
FEATURE_AI_AGENTS="false"
FEATURE_LIVE_INTEGRATION="false"
FEATURE_MIGRATION_ENGINE="false"
