{
  "name": "databridge-monorepo",
  "private": true,
  "version": "0.0.1",
  "description": "SJMS DataBridge — HE data audit, cleansing, migration and integration platform",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:root": "eslint . --ext .ts,.tsx",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules/.cache .turbo",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json,yaml}\""
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "@typescript-eslint/parser": "^7.8.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.5",
    "turbo": "^2.1.0",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.1.0"
}
