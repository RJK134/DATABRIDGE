{
  "name": "@databridge/web",
  "version": "0.1.0",
  "private": true,
  "description": "DataBridge web UI (Next.js)",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "next lint --no-cache --dir app",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf .next dist"
  },
  "dependencies": {
    "next": "^14.2.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.4"
  }
}
