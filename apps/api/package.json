{
  "name": "@databridge/api",
  "version": "0.1.0",
  "private": true,
  "description": "DataBridge Fastify API gateway",
  "main": "./dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@databridge/platform": "workspace:*",
    "@databridge/adapter-spec": "workspace:*",
    "@databridge/rule-core": "workspace:*",
    "@databridge/dhp-core": "workspace:*",
    "@databridge/canonical": "workspace:*",
    "@databridge/profile-sits": "workspace:*",
    "@databridge/profile-hesa-tdp": "workspace:*",
    "@databridge/adapter-sits-api": "workspace:*",
    "@databridge/adapter-sits-file": "workspace:*",
    "@databridge/adapter-banner-ethos": "workspace:*",
    "@databridge/adapter-banner-oracle": "workspace:*",
    "@databridge/adapter-workday-raas": "workspace:*",
    "@databridge/adapter-sjms5": "workspace:*",
    "@databridge/audit-pack-sits-native": "workspace:*",
    "@databridge/audit-pack-banner-native": "workspace:*",
    "@databridge/codeset-seeds": "workspace:*",
    "@databridge/identity-reconciler": "workspace:*",
    "@databridge/codeset-mapper": "workspace:*",
    "@databridge/effective-dating": "workspace:*",
    "@databridge/reconciliation-report": "workspace:*",
    "@databridge/migration-policy": "workspace:*",
    "@databridge/migration-runner": "workspace:*",
    "@databridge/target-adapters": "workspace:*",
    "@databridge/parallel-run-verifier": "workspace:*",
    "@databridge/pre-flight-check": "workspace:*",
    "@databridge/operational-input-queue": "workspace:*",
    "@databridge/finding-waivers": "workspace:*",
    "@databridge/finding-delta": "workspace:*",
    "@databridge/severity-by-surface": "workspace:*",
    "@databridge/finding-reproducer": "workspace:*",
    "@databridge/rule-compiler-llm": "workspace:*",
    "@databridge/findings-narrative-llm": "workspace:*",
    "@databridge/provenance-core": "workspace:*",
    "fastify": "^5.8.3",
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^12.0.0",
    "@fastify/sensible": "^6.0.0",
    "pino": "^9.2.0",
    "pino-pretty": "^11.2.1",
    "zod": "^3.23.0"
